<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        tools:context=".MainActivity">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"/>

        <!-- Password Display Area -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/textViewPassword"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/password_placeholder"
                    android:textSize="20sp"
                    android:fontFamily="monospace"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textIsSelectable="true"/>

                <ImageButton
                    android:id="@+id/buttonCopy"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_save"
                    android:contentDescription="@string/copy_button_desc"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/colorPrimary"/>

                <ImageButton
                    android:id="@+id/buttonRegenerate"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/stat_notify_sync"
                    android:contentDescription="@string/regenerate_button_desc"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/colorPrimary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Strength Indicator -->
        <TextView
            android:id="@+id/textViewStrength"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/strength_indicator"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:textColor="?attr/colorStrengthStrong"/>

        <!-- Length Selection -->
        <TextView
            android:id="@+id/textViewLengthLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/password_length_indicator"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="12dp"/>

        <SeekBar
            android:id="@+id/seekBarLength"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="127"
            android:progress="11"
            android:layout_marginBottom="32dp"/>

        <!-- Options -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/options_desc"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOutline"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkBoxUpper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:text="@string/option_uppercase"
            android:textColor="?attr/colorOnSurface"
            android:checked="true"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkBoxLower"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:text="@string/option_lowercase"
            android:textColor="?attr/colorOnSurface"
            android:checked="true"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkBoxNumbers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:text="@string/option_number"
            android:textColor="?attr/colorOnSurface"
            android:checked="true"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkBoxSymbols"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="200dp"
            android:maxWidth="320dp"
            android:text="@string/option_symbol"
            android:textColor="?attr/colorOnSurface"
            android:checked="true"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSaveFile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:padding="16dp"
            android:text="@string/save_file"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/ic_menu_save"
            android:textAllCaps="false"
            android:textSize="16sp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
