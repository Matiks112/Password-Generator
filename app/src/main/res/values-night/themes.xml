<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PasswordGenerator" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Custom attributes for Strength (Optimized for Dark) -->
        <item name="colorStrengthWeak">#FF8A80</item>       <!-- Lighter Red -->
        <item name="colorStrengthMedium">#FFD180</item>     <!-- Lighter Orange -->
        <item name="colorStrengthStrong">#B9F6CA</item>     <!-- Lighter Green -->
        <item name="colorStrengthVeryStrong">#69F0AE</item> <!-- Vibrant Green -->
    </style>
</resources>